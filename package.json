{
  "name": "desktop-mascot",
  "version": "0.1.0",
  "description": "音に合わせて踊るデスクトップマスコット (Live2D風 / 簡易リグMVP)",
  "main": "main.js",
  "scripts": {
    "build": "esbuild renderer/app.js --bundle --format=esm --outfile=renderer/dist/bundle.js",
    "watch": "esbuild renderer/app.js --bundle --format=esm --outfile=renderer/dist/bundle.js --watch",
    "start": "npm run build && electron .",
    "editor": "echo 'Open http://localhost:5050/tools/editor.html' && python3 -m http.server 5050",
    "dist": "npm run build && electron-packager . DesktopMascot --platform=darwin --arch=arm64 --out=dist-app --overwrite --prune=true"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "meyda": "^5.6.3",
    "pixi.js": "^8.5.0"
  }
}
